{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "MultiTenantPlatform",
    "Audience": "MultiTenantPlatformUsers",
    "Key": "",
    "ExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Seeding": {
    "AdminPassword": ""
  },
  "Swagger": {
    "EnabledInProduction": false
  },
  "AllowedOrigins": [],
  "AppBaseUrl": "",
  "Email": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "MultiTenant Platform",
    "EnableSsl": true
  },
  "FileStorage": {
    "BasePath": "storage",
    "MaxFileSizeBytes": 10485760
  },
  "Caching": {
    "PermissionCatalogMinutes": 10,
    "RolePermissionsMinutes": 5,
    "TenantCatalogMinutes": 5,
    "TenantDetailMinutes": 5,
    "ProductListMinutes": 3,
    "ReportSummaryMinutes": 2
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ApplyMigrationsOnStartup": true,
  "ApplySeedsOnStartup": true,
  "AllowedHosts": "*"
