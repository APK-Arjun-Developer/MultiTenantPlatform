{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "MultiTenantPlatform",
    "Audience": "MultiTenantPlatformUsers",
    "Key": "",
    "ExpiryMinutes": 60
  },
  "FileStorage": {
    "BasePath": "storage",
    "MaxFileSizeBytes": 10485760
  },
  "Caching": {
    "PermissionCatalogMinutes": 10,
    "RolePermissionsMinutes": 5,
    "TenantCatalogMinutes": 5,
    "TenantDetailMinutes": 5,
    "ProductListMinutes": 3,
    "ReportSummaryMinutes": 2
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "SeedOnStartup": false,
  "AllowedHosts": "*"
}
